# ============================================================================
# fitbyivana — Environment variables (.env.local)
# ============================================================================
# Kopiraj u .env.local i popuni vrednosti. .env.local je u .gitignore.

# ── Supabase (client-side) ──
# Iz Supabase Dashboard → Settings → API
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# ── Dev auth helpers (samo lokalno) ──
VITE_DEV_MOCK_AUTH="true"
VITE_DEV_TEST_USER_ID="00000000-0000-0000-0000-000000000000"
VITE_DEV_TEST_USER_EMAIL="dev-test@your_app.local"

# ── Web Push (VAPID public key — javan, smije u client bundle) ──
# Generate: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY="BPxxxx..."

# ── Sentry (opciono) ──
VITE_SENTRY_DSN=""

# ============================================================================
# Server-side secrets (NE stavljati u .env.local)
# Supabase Dashboard → Settings → Edge Functions → Secrets:
#
#   VAPID_PUBLIC_KEY         (isti kao VITE_VAPID_PUBLIC_KEY iznad)
#   VAPID_PRIVATE_KEY        (privatni — generisan komandom iznad)
#   VAPID_SUBJECT            (mailto:admin@fitbyivana.com)
#   CRON_SECRET              (random hex: openssl rand -hex 32)
#   SUPABASE_URL             (auto-set)
#   SUPABASE_SERVICE_ROLE_KEY (auto-set)
# ============================================================================
